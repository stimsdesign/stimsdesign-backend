---
/**
 * Users Module - Role Details
 * Displays details for a specific role.
 * 
 * Path: /dashboard/users/role/[role-slug]
 */

export const prerender = false;

// Module Menu Configuration
export const menuSkip = true;

import { db, getCachedQuery, CACHE_TTL } from "@stimsdesign/core/db.ts";
import ModuleHeader from "../../../components/layout/ModuleHeader.astro";
import Datatable from "../../../components/interface/Datatable.astro";
import StatusBadge from "../../../components/elements/StatusBadge.astro";
import FormFeedback from "../../../components/forms/FormFeedback.astro";

import TrashIcon from "../../../icons/trash.svg";

const { path } = Astro.params;
const segments = path ? path.split('/').filter(Boolean) : [];
// segments: ['users', 'role', 'role-slug']
const roleSlug = segments.length > 2 ? segments[segments.length - 1] : null;

interface RoleDetail {
    id: string;
    name: string;
    description: string | null;
    weight: number;
    user_count: number;
}

interface Permission {
    id: string;
    resource: string;
    action: string;
}

interface UserInRole {
    id: string;
    name: string;
    email: string;
    image: string | null;
    custom_image: string | null;
    avatar_bg: string | null;
    avatar_fg: string | null;
}

let role: RoleDetail | undefined;
let roleError: string | null = null;
let rolePermissions: Permission[] = [];
let allPermissions: Permission[] = [];
let groupedPermissions: Record<string, Permission[]> = {};
let allResources: string[] = [];
let usersInRole: UserInRole[] = [];

if (roleSlug) {
    // Lookup role by slug (name)
    role = await getCachedQuery(`users:roles:detail:slug:${roleSlug}`, CACHE_TTL, async () => {
        const { rows } = await db.query<RoleDetail>(`
            SELECT
                r.id,
                r.name,
                r.description,
                r.weight,
                COUNT(ur."userId")::int as user_count
            FROM "roles" r
            LEFT JOIN "user_roles" ur ON r.id = ur."roleId"
            WHERE TRIM(BOTH '-' FROM REGEXP_REPLACE(LOWER(r.name), '[^a-z0-9]+', '-', 'g')) = $1
            GROUP BY r.id
        `, [roleSlug.toLowerCase()]);
        return rows[0];
    });

    if (role) {
        // Fetch role's permissions
        rolePermissions = await getCachedQuery(`users:roles:permissions:${role.id}`, CACHE_TTL, async () => {
             const { rows } = await db.query<Permission>(`
                SELECT p.id, p.resource, p.action 
                FROM "permissions" p
                JOIN "role_permissions" rp ON p.id = rp."permissionId"
                WHERE rp."roleId" = $1
            `, [role!.id]);
            return rows;
        });
        
        // Fetch all permissions for editing
        allPermissions = await getCachedQuery('users:permissions:list', CACHE_TTL, async () => {
            const { rows } = await db.query<Permission>('SELECT * FROM "permissions" ORDER BY resource ASC, action ASC');
            return rows;
        });

        groupedPermissions = allPermissions.reduce((acc, p) => {
            if (!acc[p.resource]) acc[p.resource] = [];
            acc[p.resource].push(p);
            return acc;
        }, {} as Record<string, Permission[]>);

        // Dynamically discover all resources
        const rawModules = import.meta.glob('/src/modules/**/*.astro');
        const dynamicResources = new Set<string>();

        for (const path of Object.keys(rawModules)) {
            if (path.includes('[')) continue;
            
            const parts = path.split('/src/modules/')[1].split('/');
            if (parts.length === 2) {
                const moduleName = parts[0].toUpperCase();
                const fileName = parts[1].replace('.astro', '').toUpperCase();
                
                if (fileName === 'INDEX') {
                    dynamicResources.add(moduleName);
                } else {
                    dynamicResources.add(`${moduleName} » ${fileName}`);
                }
            }
        }
        allResources = [...new Set([...dynamicResources, ...Object.keys(groupedPermissions)])].sort();

        // Fetch users in this role
        usersInRole = await getCachedQuery(`users:roles:users:${role.id}`, CACHE_TTL, async () => {
            const { rows } = await db.query<UserInRole>(`
                SELECT u.id, u.name, u.email, u.image, u.custom_image, u.avatar_bg, u.avatar_fg
                FROM "user" u
                JOIN "user_roles" ur ON u.id = ur."userId"
                WHERE ur."roleId" = $1
            `, [role!.id]);
            return rows;
        });

    } else {
        roleError = "Role not found.";
    }
} else {
    roleError = "No role specified.";
}

// Handle update Action result if needed (though we might do client-side or form submission)
// Use the same createRole action? No, we need updateRole.
// Assuming we might have or need an updateRole action.
// Checking actions.ts... createRole exists. updateRole?
// I should check actions.ts next. For now assuming we might only display or reuse create/delete.
// I should check actions.ts next. For now assuming we might only display or reuse create/delete.
// Let's implement display first.

const isEditMode = Astro.url.searchParams.get("edit") === "true";
const currentUserRole = Astro.locals.user?.role?.toLowerCase();
const isCurrentUserSuperadmin = currentUserRole === 'superadmin';

let canEdit = true;
if (role) {
    const roleName = role.name.toLowerCase();
    if (roleName === 'superadmin') {
        canEdit = false;
    } else if (roleName === 'admin' && !isCurrentUserSuperadmin) {
        canEdit = false;
    }
}

// Redirect if trying to edit a protected role without permission
if (isEditMode && !canEdit && role) {
    return Astro.redirect(Astro.url.pathname);
}

// Handle Action Result
---

{roleError ? (
    <div class="roles-module">
        <ModuleHeader title="Role Not Found" backUrl="/dashboard/users/roles" backLabel="Return to Roles List" />
    </div>
) : (
    <div class="roles-module">
        <ModuleHeader 
            title={role!.name} 
            backUrl={isEditMode ? Astro.url.pathname : "/dashboard/users/roles"}
            backLabel={isEditMode ? "Return to Role" : "Back to Roles"}
        >
            {isEditMode && (
                <svg slot="title-icon" class="w-10 h-10 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path>
                </svg>
            )}
        </ModuleHeader>
        {isEditMode ? (
            <form id="edit-role-form" method="POST" class="form-container">
                <input type="hidden" name="id" value={role!.id} />
                <h5>Role Details</h5>
                <div class="form-grid">
                    <div class="input-group">
                        <label for="name">Role Name</label>
                        <input type="text" id="name" name="name" value={role!.name} required />
                    </div>

                    <div class="input-group">
                        <label for="description">Description</label>
                        <input type="text" id="roleDesc" name="description" placeholder="Short description of the role..." value={role!.description} />
                    </div>

                    <div class="input-group">
                        <label for="weight">Weight (Priority)</label>
                        {['superadmin', 'admin'].includes(role!.name.toLowerCase()) ? (
                            <>
                                <input type="number" id="weight" name="weight" value={role!.weight} required min="0" readonly style="cursor: not-allowed;" title="Weight is protected for this role" />
                                <span class="small warning">&nbsp;Weight cannot be changed for {role!.name}.</span>
                            </>
                        ) : role!.name.toLowerCase() === 'user' ? (
                            <>
                                <input type="hidden" name="weight" value={role!.weight} />
                                <input type="text" id="weight" value="--" readonly style="cursor: not-allowed;" title="Weight is protected for this role" />
                                <span class="small warning">&nbsp;Weight cannot be changed for {role!.name}.</span>
                            </>
                        ) : (
                            <>
                                <input type="number" id="weight" name="weight" value={role!.weight} required min="2" max="9998" />
                                <span class="small">&nbsp;Lower numbers have higher priority.</span>
                            </>
                        )}
                    </div>
                </div>

                <h3>Set Role Permissions</h3>
                <div class="form-grid">
                    <div class="input-row">
                        <div class="input-group">
                            <label for="moduleSelect">Select Module or Sub-Module</label>
                            <p class="small">Selecting a base Module will automatically select all its sub-modules.</p>
                            <select id="moduleSelect" name="moduleSelect">
                                <option value="" disabled selected>Select a module or sub-module...</option>
                                {allResources.map(resource => (
                                    <option value={resource}>{resource}</option>
                                ))}
                            </select>
                        </div>
                    </div>
                    <div class="input-row">
                        <div class="selection-box">
                            <span>Permissions</span>
                            {allResources.map((resource: string) => {
                                const perms = groupedPermissions[resource] || [];
                                return (
                                <div class="checkbox-group" data-resource={resource} style="display: none;">
                                    <span>{resource} <span class="remove" data-resource={resource} style="cursor: pointer; display: inline-flex; align-items: center; justify-content: center; width: 20px; height: 20px; border-radius: 50%; color: var(--text-muted); transition: color 0.15s ease;">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                                    </span></span>
                                    <div class="checkbox-list">
                                        {perms.map((p: Permission) => (
                                            <label class="checkbox-option" style="min-width: unset;">
                                                <input type="checkbox" name="permissions" value={p.id} checked={rolePermissions.some(rp => rp.id === p.id)}  />
                                                <span class="checkmark"></span>
                                                {p.action}
                                            </label>
                                        ))}
                                        {perms.length === 0 && <span class="text-muted small">No permissions defined.</span>}
                                    </div>
                                </div>
                                );
                            })}
                        </div>
                    </div>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    {['superadmin', 'admin', 'user'].includes(role!.name.toLowerCase()) ? (
                        <button type="button" class="btn btn-delete" disabled title="Protected role cannot be deleted">Delete Role</button>
                    ) : (
                        <button type="button" id="btn-delete-role" class="btn btn-delete">Delete Role</button>
                    )}
                </div>
                <FormFeedback id="edit-role-feedback" />
            </form>
) : (
    <div class="module-card">
        <h5>Role Details</h5>
        <ul class="properties-list">
            <li><strong>Name:</strong> {role!.name}</li>
            <li><strong>Weight:</strong> {role!.name.toLowerCase() === 'user' ? '--' : role!.weight}</li>
            <li><strong>Description:</strong> {role!.description || "No description"}</li>
            <li><strong>Users Assigned:</strong> {role!.user_count}</li>
        </ul>
        <h5>Permissions</h5>
        <div class="flex flex-col gap-4">
            {Object.entries(groupedPermissions)
                .filter(([, perms]) => perms.some(p => rolePermissions.some(rp => rp.id === p.id)))
                .map(([resource, perms]: [string, Permission[]]) => (
                <ul class="group-properties-list">
                    <li><strong>{resource}</strong></li>
                    <li>
                        {perms.filter(p => rolePermissions.some(rp => rp.id === p.id)).map(p => (
                            <StatusBadge type="info" label={p.action} />
                        ))}
                    </li>
                </ul>
            ))}
            {rolePermissions.length === 0 && (
                <span class="text-muted text-sm">Role has no assigned permissions.</span>
            )}
        </div>
    </div>
    <div class="mb-16">
        {canEdit ? (
            <a href={`?edit=true`} class="btn btn-primary">Edit Role</a>
        ) : (
            <button class="btn btn-primary" disabled style="opacity: 0.5; cursor: not-allowed;" title="You do not have permission to edit this role.">Edit Role</button>
        )}
    </div>
    )}
    <h5>Users in this Role</h5>
    <Datatable id="role-users-table" searchable={true} sortable={true} perPage={10} classes="table-container">
        <table id="role-users-table">
            <thead>
                <tr>
                    <th class="preferred desc"><span>Name</span></th>
                    <th><span>Email</span></th>
                    <th><span>Actions</span></th>
                </tr>
            </thead>
            <tbody>
            {usersInRole.map((user) => {
                const getUserInitials = (name: string) => {
                    const parts = name.split(' ').filter(Boolean);
                    return parts.length > 1 
                        ? (parts[0][0] + parts[parts.length - 1][0]).toUpperCase() 
                        : (parts[0]?.[0] || 'U').toUpperCase();
                };

                const initials = user ? getUserInitials(user.name) : '';
                const avatarBg = user!.avatar_bg;
                const avatarFg = user!.avatar_fg;

                return (
                <tr>
                    <td>
                        <div class="flex items-center gap-3">
                            {user!.image ? (
                                <div class="avatar-wrapper">
                                    <img class="avatar-img" src={user!.image} alt={user!.name} style={`display: block; border: 2px solid ${avatarFg};`} />
                                </div>
                            ) : (
                                <div class="avatar-wrapper">
                                    <span class="initials-avatar" style={`display: flex; background-color: ${avatarBg}; color: ${avatarFg}; border: 2px solid ${avatarFg};`}>{initials}</span>
                                </div>
                            )}
                            <a href={`/dashboard/users/user/${encodeURIComponent(user!.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, ''))}`}>
                                <strong>{user!.name}</strong>
                            </a>
                        </div>
                    </td>
                    <td>{user.email}</td>
                    <td>
                        {role!.name.toLowerCase() === 'superadmin' ? (
                            <button class="btn-icon" disabled style="opacity: 0.3; cursor: not-allowed;" title="Superadmin assignments are protected">
                                <TrashIcon />
                            </button>
                        ) : (
                            <button class="btn-icon btn-delete-user-role" data-user-id={user.id} data-role-id={role!.id} title="Remove User from Role">
                                <TrashIcon />
                            </button>
                        )}
                    </td>
                </tr>
                );
            })}
            {usersInRole.length === 0 && (
                <tr>
                    <td colspan="3" class="text-center">No users assigned to this role.</td>
                </tr>
            )}
            </tbody>
        </table>
    </Datatable>
</div>
)}

<script>
    import { actions } from "astro:actions";
    import { navigate } from "astro:transitions/client";

    document.addEventListener('astro:page-load', () => {
        const editRoleForm = document.getElementById('edit-role-form') as HTMLFormElement;
        const feedback = document.getElementById('edit-role-feedback');
        const deleteBtn = document.getElementById('btn-delete-role');

        if (!(window as any)._roleDeleteListenerAttached) {
            document.addEventListener('click', async (e) => {
                const target = e.target as HTMLElement;
                const btn = target.closest('.btn-delete-user-role');
                if (!btn) return;

                const userId = (btn as HTMLElement).dataset.userId;
                const roleId = (btn as HTMLElement).dataset.roleId;

                if (!userId || !roleId) return;

                const icon = btn.querySelector('svg')?.outerHTML;
                (window as any).stimsToast.confirm('Are you sure you want to remove this user from the role?', async () => {
                    const { error } = await actions.users.removeUserFromRole({ userId, roleId });
                    
                    if (error) {
                        (window as any).stimsToast.show(error.message, 'error');
                    } else {
                        (window as any).stimsToast.show('User removed from role successfully!');
                        navigate(window.location.pathname, { history: 'replace' }); 
                    }
                }, null, 'success', icon);
            });
            (window as any)._roleDeleteListenerAttached = true;
        }

        if (deleteBtn) {
             deleteBtn.addEventListener('click', async () => {
                const icon = deleteBtn.querySelector('svg')?.outerHTML;
                (window as any).stimsToast.confirm('Are you sure you want to delete this role? This action cannot be undone.', async () => {
                     const roleIdInput = editRoleForm.querySelector('input[name="id"]') as HTMLInputElement;
                     const roleId = roleIdInput?.value;

                     if (!roleId) return;
                     
                     if (feedback) {
                        feedback.className = 'form-feedback feedback loading';
                        feedback.textContent = 'Deleting role...';
                        feedback.style.display = 'block';
                    }

                     const { error } = await actions.users.deleteRole({ id: roleId });
                     
                     if (error) {
                          if (feedback) {
                            feedback.className = 'form-feedback feedback error';
                            feedback.textContent = `Error: ${error.message}`;
                            feedback.style.display = 'block';
                         }
 else {
                             (window as any).stimsToast.show(error.message, 'error');
                         }
                     } else {
                         (window as any).stimsToast.show('Role deleted successfully!');
                         navigate('/dashboard/users/roles');
                     }
                }, null, 'warning', icon);
             });
        }

        if (editRoleForm && feedback) {
            function initializePicklist() {
                const select = document.getElementById('moduleSelect') as HTMLSelectElement;
                const selectionBox = document.querySelector('.selection-box') as HTMLElement;
                if (!select || !selectionBox) return;

                const allGroups = selectionBox.querySelectorAll('.checkbox-group');
                
                // Initial state
                allGroups.forEach((group: Element) => {
                    const g = group as HTMLElement;
                    const res = g.dataset.resource;
                    const hasChecked = g.querySelectorAll('input[type="checkbox"]:checked').length > 0;
                    
                    if (hasChecked && res) {
                        g.style.display = 'block';
                        const option = select.querySelector(`option[value="${res}"]`) as HTMLOptionElement;
                        if (option) {
                            option.style.display = 'none';
                            option.disabled = true;
                        }
                    }
                });

                select.addEventListener('change', (e) => {
                    const selectedResource = (e.target as HTMLSelectElement).value;
                    if (!selectedResource) return;

                    const group = selectionBox.querySelector(`.checkbox-group[data-resource="${selectedResource}"]`) as HTMLElement;
                    if (group) {
                        group.style.display = 'block';
                    }
                    
                    allGroups.forEach((g) => {
                        const res = (g as HTMLElement).dataset.resource;
                        if (res && res.startsWith(`${selectedResource} »`)) {
                            (g as HTMLElement).style.display = 'block';
                            const subOption = select.querySelector(`option[value="${res}"]`) as HTMLOptionElement;
                            if (subOption) {
                                subOption.style.display = 'none';
                                subOption.disabled = true;
                            }
                        }
                    });

                    const option = select.querySelector(`option[value="${selectedResource}"]`) as HTMLOptionElement;
                    if (option) {
                        option.style.display = 'none';
                        option.disabled = true;
                    }
                    
                    select.value = "";
                });

                selectionBox.addEventListener('click', (e) => {
                    const removeBtn = (e.target as HTMLElement).closest('.remove');
                    if (!removeBtn) return;
                    
                    const resourceToRemove = (removeBtn as HTMLElement).dataset.resource;
                    if (!resourceToRemove) return;

                    const group = selectionBox.querySelector(`.checkbox-group[data-resource="${resourceToRemove}"]`) as HTMLElement;
                    if (group) {
                        group.style.display = 'none';
                        const checkboxes = group.querySelectorAll('input[type="checkbox"]');
                        checkboxes.forEach((cb) => (cb as HTMLInputElement).checked = false);
                    }

                    const option = select.querySelector(`option[value="${resourceToRemove}"]`) as HTMLOptionElement;
                    if (option) {
                        option.style.display = '';
                        option.disabled = false;
                    }
                    
                    allGroups.forEach((g) => {
                        const res = (g as HTMLElement).dataset.resource;
                        if (res && res.startsWith(`${resourceToRemove} »`)) {
                            (g as HTMLElement).style.display = 'none';
                            const subCheckboxes = g.querySelectorAll('input[type="checkbox"]');
                            subCheckboxes.forEach((cb) => (cb as HTMLInputElement).checked = false);
                            
                            const subOption = select.querySelector(`option[value="${res}"]`) as HTMLOptionElement;
                            if (subOption) {
                                subOption.style.display = '';
                                subOption.disabled = false;
                            }
                        }
                    });
                });
            }

            initializePicklist();

            editRoleForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                
                const formData = new FormData(editRoleForm);
                feedback.style.display = 'block';
                feedback.className = 'form-feedback feedback loading';
                feedback.textContent = 'Saving changes...';
                feedback.style.display = 'block';

                const { data: result, error } = await actions.users.updateRole(formData);

                if (error) {
                    feedback.className = 'form-feedback feedback error';
                    // Parse error message (remove "ZodError: " or JSON junk if present)
                    let msg = error.message;
                    try {
                        // Some Action errors come as stringified JSON if it's a validation error
                        if (msg.startsWith('[')) {
                            const parsed = JSON.parse(msg);
                            if (Array.isArray(parsed) && parsed[0]?.message) {
                                msg = parsed[0].message;
                            }
                        }
                    } catch (e) {
                        // Keep original message
                    }
                    
                    feedback.textContent = `Error: ${msg}`;
                    feedback.style.display = 'block';
                }
 else if (result?.success) {
                    const currentPath = window.location.pathname;
                    const newName = result.name || '';
                    const newSlug = newName.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
                    
                    const pathParts = currentPath.split('/');
                    if (pathParts[pathParts.length - 1] !== newSlug) {
                        pathParts[pathParts.length - 1] = encodeURIComponent(newSlug);
                        navigate(pathParts.join('/')); 
                    } else {
                        navigate(currentPath);
                    }
                }
            });
        }
    });
</script>
