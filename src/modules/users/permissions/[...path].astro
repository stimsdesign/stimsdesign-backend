---
/**
 * Users Module - Permission Details
 * Displays details for a specific permission.
 * 
 * Path: /dashboard/users/permissions/[permission-id]
 */

export const prerender = false;

// Module Menu Configuration
export const menuSkip = true;

import { db, getCachedQuery, CACHE_TTL } from "@stimsdesign/core/db.ts";
import ModuleHeader from "../../../components/layout/ModuleHeader.astro";
import FormFeedback from "../../../components/forms/FormFeedback.astro";

const { path } = Astro.params;
const segments = path ? path.split('/').filter(Boolean) : [];
// segments: ['users', 'permissions', 'permission-id']
// permission-id might contain colons, need to decode.
const permissionIdEncoded = segments.length > 2 ? segments[segments.length - 1] : null;
const permissionId = permissionIdEncoded ? decodeURIComponent(permissionIdEncoded) : null;

interface PermissionDetail {
    id: string;
    resource: string;
    action: string;
    description: string | null;
}

let permission: PermissionDetail | undefined;
let permissionError: string | null = null;

if (permissionId) {
    // Lookup permission by ID
    permission = await getCachedQuery(`users:permissions:detail:${permissionId}`, CACHE_TTL, async () => {
        const { rows } = await db.query<PermissionDetail>(`
            SELECT * FROM "permissions" WHERE id = $1
        `, [permissionId]);
        return rows[0];
    });

    if (!permission) {
        permissionError = "Permission not found.";
    }
} else {
    permissionError = "No permission specified.";
}

const isEditMode = Astro.url.searchParams.get("edit") === "true";

---

{permissionError ? (
    <div class="permissions-module">
        <ModuleHeader title="Permission Not Found" backUrl="/dashboard/users/permissions" backLabel="Return to Permissions List" />
    </div>
) : (
    <div class="permissions-module">
        <ModuleHeader 
            title={`${permission!.resource} / ${permission!.action}`}
            backUrl={isEditMode ? Astro.url.pathname : "/dashboard/users/permissions"}
            backLabel={isEditMode ? "Return to Details" : "Back to List"}
        />

        {isEditMode ? (
            <form id="edit-perm-form" method="POST" class="form-container">
                <input type="hidden" name="id" value={permission!.id} />
                
                <div class="form-grid">
                    <div class="input-row">
                        <div class="input-group">
                            <label>Module (Resource)</label>
                            <input type="text" value={permission!.resource} disabled class="disabled-input" />
                            <span class="small">Resource cannot be changed.</span>
                        </div>
                        <div class="input-group">
                            <label>Permission (Action)</label>
                            <input type="text" value={permission!.action} disabled class="disabled-input" />
                            <span class="small">Action cannot be changed.</span>
                        </div>
                    </div>

                    <div class="input-row">
                         <div class="input-group">
                            <label for="description">Description</label>
                            <input type="text" id="description" name="description" value={permission!.description || ""} />
                         </div>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    {!['read', 'write', 'delete'].includes(permission!.action) ? (
                        <button type="button" id="delete-btn" class="btn btn-delete" data-id={permission!.id}>Delete Permission</button>
                    ) : (
                         <button type="button" class="btn btn-delete" disabled title="Default permissions cannot be deleted">Delete Permission</button>
                    )}
                </div>
                <FormFeedback id="edit-feedback" />
            </form>
        ) : (
            <div class="module-card">
                <h5>Details</h5>
                <ul class="properties-list">
                    <li><strong>ID:</strong> {permission!.id}</li>
                    <li><strong>Module:</strong> {permission!.resource}</li>
                    <li><strong>Action:</strong> {permission!.action}</li>
                    <li><strong>Description:</strong> {permission!.description || "-"}</li>
                </ul>
            </div>
        )}

        {!isEditMode && (
             <div class="mt-6 flex gap-4">
                <a href="?edit=true" class="btn btn-primary">Edit Permission</a>
             </div>
        )}
    </div>
)}

<script>
    import { actions } from "astro:actions";
    import { navigate } from "astro:transitions/client";

    // Edit Form
    const editForm = document.getElementById('edit-perm-form') as HTMLFormElement;
    const feedback = document.getElementById('edit-feedback');

    if (editForm) {
        editForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(editForm);
            
            if (feedback) {
                feedback.className = 'form-feedback feedback loading';
                feedback.textContent = 'Saving changes...';
                feedback.style.display = 'block';
            }

            const { error } = await actions.users.updatePermission(formData);

            if (error) {
                if (feedback) {
                    feedback.className = 'form-feedback feedback error';
                    feedback.textContent = `Error: ${error.message}`;
                    feedback.style.display = 'block';
                }
            } else {
                 // Reload to show view mode with updated data
                 navigate(window.location.pathname, { history: 'replace' });
            }
        });
    }

    // Delete Action
    const deleteBtn = document.getElementById('delete-btn');
    if (deleteBtn) {
        deleteBtn.addEventListener('click', async () => {
            const id = deleteBtn.getAttribute('data-id');
             const icon = deleteBtn.querySelector('svg')?.outerHTML;
             (window as any).stimsToast.confirm('Are you sure you want to delete this permission? THIS CANNOT BE UNDONE.', async () => {
                const { error } = await actions.users.deletePermission({ id: id! });
                if (error) {
                    (window as any).stimsToast.show(error.message, 'error');
                } else {
                    (window as any).stimsToast.show('Permission deleted successfully!');
                    navigate('/dashboard/users/permissions');
                }
            }, null, 'warning', icon);
        });
    }
</script>

<style>
    .disabled-input {
        background-color: var(--color-surface-200);
        color: var(--color-foreground-muted);
        cursor: not-allowed;
        border-color: var(--color-border);
    }

</style>
